# ==============================
# 1. Python 运行时的缓存文件
# ==============================
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/

# ==============================
# 2. 虚拟环境目录（比如你装库的地方）
# ==============================
venv/
env/
.env/
miniconda/

# ==============================
# 3. 日志文件 (运行产生的日志不要传)
# ==============================
*.log
logs/

# ==============================
# 4. 🈲 核心警告：模型权重与预训练文件
# Git 适合管代码(几十KB)，绝不能管模型(几百MB~几个GB)！
# ==============================
assets/weights/*.pkl
assets/weights/*.pt
assets/weights/bert/
assets/models/

# ==============================
# 5. 🈲 核心警告：敏感信息与大文件数据
# ==============================
.env
# 如果 dataset.csv 超过 50MB，建议取消下面这行的注释将其忽略。
# 如果只有几MB，可以保留在 Git 里方便别人拉取。
# assets/dataset/dataset.csv